# Server
NODE_ENV=production
PORT=3000
API_URL=https://api.elite.dating

# PostgreSQL
DATABASE_URL=postgres://elite:elite_secret@postgres:5432/elite

# Redis
REDIS_URL=redis://redis:6379

# MinIO (S3-compatible object storage)
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=elite_minio_access
MINIO_SECRET_KEY=elite_minio_secret
MINIO_USE_SSL=false

# JWT
JWT_SECRET=replace-with-a-64-char-random-hex-string
JWT_REFRESH_SECRET=replace-with-another-64-char-random-hex-string

# Apple Sign In
APPLE_TEAM_ID=YOUR_TEAM_ID
APPLE_KEY_ID=YOUR_KEY_ID
APPLE_BUNDLE_ID=com.elite.dating
